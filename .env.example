# ----------------------------------------------------------------------------
# Second Chapter Connections — environment variables
# Copy this file to .env and fill in values from YOUR OWN Supabase/Stripe/etc.
# ----------------------------------------------------------------------------

# --- Supabase (your own project: Project Settings -> API) -------------------
# Public values (safe to expose to the browser). VITE_ vars are inlined at build.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Same values, read by the server during SSR.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# SECRET — server only. Project Settings -> API -> service_role key.
# Required for admin console, applications, contact form, and all privileged server functions.
SUPABASE_SERVICE_ROLE_KEY=

# Personal access token — https://supabase.com/dashboard/account/tokens
# Used only by `npm run supabase:auth-config` (local setup). Never commit .env.
SUPABASE_ACCESS_TOKEN=

# --- Cloudflare Turnstile (CAPTCHA on apply, auth, contact) ----------------
# Option A — Global API Key + email (scripts use X-Auth-Email / X-Auth-Key):
#   CLOUDFLARE_EMAIL=
#   CLOUDFLARE_GLOBAL_API_KEY=
#   CLOUDFLARE_ACCOUNT_ID=
# Option B — scoped API token: CLOUDFLARE_API_TOKEN + CLOUDFLARE_ACCOUNT_ID
# Option C — run: npm run cloudflare:turnstile-setup (creates widget, writes keys below)
CLOUDFLARE_EMAIL=
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Resend (optional — used by scripts/resend-smtp-setup.mjs) -----------------
# RESEND_API_KEY=re_your_resend_api_key

# --- Supabase custom SMTP (password reset emails) ----------------------------
# Used by `npm run supabase:smtp-config` — not needed on Vercel.
# Resend example (verify inm8tebook.net in Resend first):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_resend_api_key
# SMTP_ADMIN_EMAIL=support@inm8tebook.net
# SMTP_SENDER_NAME=Anew
# SMTP_AUTOCONFIRM=true

# --- Stripe (optional — NOT needed for free-only launch) --------------------
# Client publishable key used by the checkout UI (pk_test_… or pk_live_…).
# Its prefix also selects the environment: pk_test_ => sandbox, pk_live_ => live.
VITE_PAYMENTS_CLIENT_TOKEN=
# Server-side SECRET keys from Stripe Dashboard -> Developers -> API keys.
# sandbox = your test-mode secret (sk_test_…), live = production (sk_live_…).
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
# Stripe webhook signing secrets (Stripe Dashboard -> Developers -> Webhooks).
# Point a webhook endpoint at /api/public/payments/webhook?env=sandbox (and ?env=live).
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=
