# ----------------------------------------------------------------------------
# Second Chapter Connections — environment variables
# Copy this file to .env and fill in values from YOUR OWN Supabase/Stripe/etc.
# ----------------------------------------------------------------------------

# --- Supabase (your own project: Project Settings -> API) -------------------
# Public values (safe to expose to the browser). VITE_ vars are inlined at build.
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Same values, read by the server during SSR.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# SECRET — server only. Project Settings -> API -> service_role key.
# Required for the entire admin console and all privileged server functions.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (CAPTCHA on auth + contact forms) -----------------
# Without these the widget falls back to a dev-bypass token (fine locally,
# NOT acceptable in production).
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Stripe (subscriptions/payments) ----------------------------------------
# Client publishable token used by the checkout UI.
VITE_PAYMENTS_CLIENT_TOKEN=
# Server-side secret keys (sandbox = test mode, live = production).
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
# Stripe webhook signing secrets (Stripe Dashboard -> Developers -> Webhooks).
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=
